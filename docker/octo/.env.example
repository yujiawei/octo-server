# -----------------------------------------------------------------------------
# OCTO Server · docker/octo stack environment
# -----------------------------------------------------------------------------
# Copy this file to `.env` and adjust the values for your deployment:
#
#     cp docker/octo/.env.example docker/octo/.env
#
# At minimum you MUST change:
#   - MYSQL_ROOT_PASSWORD
#   - MINIO_ROOT_PASSWORD
#   - OCTO_MASTER_KEY  (generate with `openssl rand -hex 16`)
#
# Everything else has sane defaults for a single-host dev deployment.
# -----------------------------------------------------------------------------

# --- Domain & host --------------------------------------------------------
# The hostname nginx will serve. Add an entry like
#   127.0.0.1 octo.local
# to /etc/hosts on the machine where you will browse the stack from.
OCTO_DOMAIN=octo.local
# External IP/hostname that WuKongIM will advertise to mobile/web clients.
# Use your LAN IP if you want to connect from other devices.
OCTO_EXTERNAL_IP=127.0.0.1

# --- Port mapping (host side) ---------------------------------------------
# Chosen to avoid collisions with typical local services.
OCTO_HTTP_PORT=28080
OCTO_HTTPS_PORT=28443
OCTO_SERVER_PORT=28081
OCTO_ADMIN_PORT=28082
OCTO_WEB_PORT=28083
OCTO_WK_API_PORT=25001
OCTO_WK_TCP_PORT=25100
OCTO_WK_WS_PORT=25200
OCTO_WK_MONITOR_PORT=25300
OCTO_MYSQL_PORT=23306
OCTO_REDIS_PORT=26379
OCTO_MINIO_API_PORT=29000
OCTO_MINIO_CONSOLE_PORT=29001

# --- Docker network -------------------------------------------------------
# Dedicated subnet so the stack does not clash with other bridge networks.
OCTO_NETWORK_SUBNET=172.28.0.0/16

# --- Timezone -------------------------------------------------------------
TZ=UTC

# --- MySQL ----------------------------------------------------------------
MYSQL_ROOT_PASSWORD=CHANGE_ME_MYSQL_PASSWORD
MYSQL_DATABASE=octo

# --- Redis ----------------------------------------------------------------
# (no required settings — redis is unauthenticated on the internal network)

# --- MinIO (S3-compatible object storage) ---------------------------------
MINIO_ROOT_USER=octoadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_SERVER_URL=http://localhost:29000
MINIO_BROWSER_REDIRECT_URL=http://localhost:29001

# --- WuKongIM -------------------------------------------------------------
# debug | release | bench
WK_MODE=debug

# --- OCTO Server ----------------------------------------------------------
# Master key for at-rest encryption of user credentials (Bot tokens, OAuth
# secrets, etc.). MUST be exactly 32 bytes. Generate with:
#     openssl rand -hex 16
# Losing this key makes previously encrypted secrets unrecoverable.
OCTO_MASTER_KEY=CHANGE_ME_32_BYTES_octo_master_k

# Optional HMAC-SHA256 shared secret for inbound webhooks. Leave blank to
# disable signature verification (NOT recommended in production).
OCTO_WEBHOOK_SECRET_KEY=
